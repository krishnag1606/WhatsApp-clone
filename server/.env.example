DB_USERNAME=your_mongodb_username_here
DB_PASSWORD=your_mongodb_password_here

# Server Configuration
PORT=8000

# CORS Configuration (Frontend URL)
FRONTEND_URL=http://localhost:3000

# Google OAuth — used for server-side verification of the client credential.
# Must match REACT_APP_GOOGLE_CLIENT_ID in apps/client-ui/.env
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Secret for signing Flux session JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=your_random_jwt_secret_here

# AES-256-GCM key for at-rest message encryption (32 bytes).
# Generate with: openssl rand -hex 32   (64 hex chars)
MESSAGE_ENCRYPTION_KEY=your_32_byte_hex_or_base64_key_here
